{
  "name": "@k-codex/yandex-direct-sdk",
  "version": "0.1.0",
  "description": "Core transport/auth foundation for Yandex Direct API SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run build --silent && node --test tests/*.test.mjs",
    "test:contract": "npm run build --silent && node --test tests/contract-*.test.mjs",
    "example:basic": "npm run build --silent && node examples/basic.mjs",
    "example:adgroups": "npm run build --silent && node examples/adgroups-mvp.mjs",
    "example:reports": "npm run build --silent && node examples/reports.mjs",
    "validate": "npm run typecheck && npm test"
  },
  "keywords": [
    "yandex",
    "direct",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.4.0",
    "typescript": "^5.9.2"
  }
}
